# UPI Payment Configuration
# Replace with your school's actual UPI details

# Your school's UPI ID (required)
SCHOOL_UPI_ID=yourschool@paytm

# School/Organization name (required) 
SCHOOL_NAME="VidyaSetu School"

# Merchant name for payments (optional - defaults to SCHOOL_NAME)
MERCHANT_NAME="VidyaSetu School Fee Payment"

# Merchant code (optional)
MERCHANT_CODE=VS001

# Currency (default: INR)
CURRENCY=INR

# Maximum amount per transaction (in rupees, default: 100000)
MAX_UPI_AMOUNT=100000

# Environment (development/production)
NODE_ENV=development

# Optional: Storage bucket for payment proofs (if using file storage)
PAYMENT_STORAGE_BUCKET=payment-documents

# Optional: Email notifications
PAYMENT_NOTIFICATION_EMAIL=admin@yourschool.com

# Optional: SMS notifications settings
ENABLE_SMS_NOTIFICATIONS=false
SMS_PROVIDER_API_KEY=your_sms_api_key

# OpenAI Configuration for EduCartoon AI
# Get your API key from: https://platform.openai.com/api-keys

# Required: OpenAI API Key
REACT_APP_OPENAI_API_KEY=your-openai-api-key-here

# Optional: OpenAI Model (default: gpt-3.5-turbo)
# Available options: gpt-3.5-turbo, gpt-4, gpt-4-turbo-preview
REACT_APP_OPENAI_MODEL=gpt-3.5-turbo

# Optional: Max tokens per response (default: 500)
REACT_APP_OPENAI_MAX_TOKENS=500

# Optional: Temperature for AI responses (default: 0.7)
# Range: 0.0 (deterministic) to 1.0 (creative)
REACT_APP_OPENAI_TEMPERATURE=0.7

# ====================================================
# FACIAL RECOGNITION CONFIGURATION
# ====================================================

# Facial Recognition Provider
# Options: 'offline', 'aws', 'azure', 'google'
# Recommended: 'offline' for privacy and no API costs
REACT_APP_FACE_RECOGNITION_PROVIDER=offline

# Encryption Key for Face Data Security
# IMPORTANT: Generate a strong 32-character key for production
# You can generate one using: require('crypto').randomBytes(32).toString('hex')
REACT_APP_FACE_ENCRYPTION_KEY=1c7daf864124b290657b61107eb0fda533e5faef5bafa6a9c430ced403749973

# Face Recognition Confidence Thresholds
# Default confidence threshold (0.0 to 1.0)
REACT_APP_FACE_DEFAULT_CONFIDENCE=0.8

# High accuracy threshold for critical operations
REACT_APP_FACE_HIGH_ACCURACY_THRESHOLD=0.9

# Image Processing Settings
REACT_APP_FACE_MAX_IMAGE_SIZE=2097152
REACT_APP_FACE_TARGET_WIDTH=300
REACT_APP_FACE_TARGET_HEIGHT=300

# Storage Bucket Names (should match your Supabase buckets)
REACT_APP_FACE_TEMPLATES_BUCKET=facial-templates
REACT_APP_FACE_EVENTS_BUCKET=facial-events

# Model Loading Path for Offline Processing
REACT_APP_FACE_MODELS_PATH=/models/face-recognition

# Performance Settings
REACT_APP_FACE_MAX_RECOGNITION_TIME=10000
REACT_APP_FACE_ENABLE_GPU_ACCELERATION=false

# Audit and Cleanup Settings
REACT_APP_FACE_CLEANUP_INTERVAL_DAYS=180
REACT_APP_FACE_ENABLE_DETAILED_LOGGING=true

# Development/Debug Settings
REACT_APP_FACE_ENABLE_DEBUG_MODE=true
REACT_APP_FACE_STUB_MODE_FOR_TESTING=false

# ====================================================
# CLOUD PROVIDER CONFIGURATIONS (Optional)
# Only configure if not using offline mode
# ====================================================

# AWS Rekognition Configuration
# REACT_APP_AWS_ACCESS_KEY_ID=your-aws-access-key
# REACT_APP_AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# REACT_APP_AWS_REGION=us-east-1
# REACT_APP_AWS_REKOGNITION_COLLECTION=school-faces

# Azure Face API Configuration  
# REACT_APP_AZURE_FACE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
# REACT_APP_AZURE_FACE_KEY=your-azure-subscription-key
# REACT_APP_AZURE_FACE_PERSON_GROUP=school-persons

# Google Cloud Vision Configuration
# REACT_APP_GOOGLE_CLOUD_PROJECT_ID=your-project-id
# REACT_APP_GOOGLE_CLOUD_KEY_FILE=path/to/service-account.json

# Instructions:
# 1. Replace 'your-32-character-encryption-key-here' with a strong encryption key
# 2. Update SCHOOL_UPI_ID and other payment details for your school
# 3. Add your OpenAI API key if using AI features
# 4. Restart your development server after making changes
# 5. Never commit this .env file to version control